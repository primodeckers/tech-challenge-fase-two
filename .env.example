# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.

# Rastreamento de experimentos (MLflow)
# Padrão: SQLite local (funciona sem servidor e suporta Model Registry). Para
# usar o servidor central, suba-o (docker compose up mlflow) e use http://localhost:5000
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=recomendador-ecommerce

# Caminhos de dados
RAW_DATA_PATH=data/raw/events.csv
PROCESSED_DATA_DIR=data/processed
MODEL_OUTPUT_DIR=models

# Semente aleatória (reprodutibilidade)
RANDOM_SEED=42
